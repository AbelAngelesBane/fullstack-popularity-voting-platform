{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./", 
    "ignoreDeprecations": "6.0", 
    "moduleResolution": "bundler", 
    "paths": {
      "@/*": [
        "./*"
      ],
      "nativewind/utils": ["./node_modules/nativewind/dist/utils"]
    },
    
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
, "metro.config.ts", "metro.config.ts"  ]
}
