generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?   @unique
  role          String?   @default("user")
  emailVerified Boolean   @default(false)
  image         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  banned        Boolean?
  accounts      Account[]
  comments      Comment[]
  invoices      Invoice[]
  createdPolls  Poll[]    @relation("pollAuthor")
  editedPolls   Poll[]    @relation("pollEditor")
  sessions      Session[]
  votes         Vote[]
  notifications Notification[] 

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_userId_fkey")
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "account_userId_fkey")
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Poll {
  id         String    @id @default(uuid())
  authorId   String?
  editedById String?
  categoryId String
  name       String
  createdAt  DateTime  @default(now())
  deadline   DateTime
  updatedAt  DateTime  @updatedAt
  active     Boolean   @default(false)
  archived   Boolean   @default(false)
  notified Boolean @default(false)
  banner     String?
  archivedAt DateTime?
  comments   Comment[]
  invoices   Invoice[]
  options    Option[]
  author     User?     @relation("pollAuthor", fields: [authorId], references: [id])
  category   Category  @relation(fields: [categoryId], references: [id])
  editedBy   User?     @relation("pollEditor", fields: [editedById], references: [id])
  votes      Vote[]

  @@index([deadline])
  @@index([authorId], map: "poll_authorId_fkey")
  @@index([categoryId], map: "poll_categoryId_fkey")
  @@index([editedById], map: "poll_editedById_fkey")
  @@map("poll")
}

model Category {
  id    String @id @default(uuid())
  title String
  polls Poll[]

  @@map("category")
}

model Nominee {
  id      String   @id @default(uuid())
  name    String
  bio     String?  @db.Text
  avatar  String?  @db.Text
  options Option[]

  @@map("nominee")
}

model Option {
  id        String  @id @default(uuid())
  pollId    String
  nomineeId String
  nominee   Nominee @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  poll      Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     Vote[]

  @@unique([pollId, nomineeId])
  @@index([nomineeId], map: "option_nomineeId_fkey")
  @@map("option")
}

model Comment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  createdAt DateTime @default(now())
  authorId  String
  pollId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([authorId], map: "comment_authorId_fkey")
  @@index([pollId], map: "comment_pollId_fkey")
  @@map("comment")
}

model Vote {
  id        String      @id @default(uuid())
  deviceId  String?
  tier      PricingTier @default(FREE)
  createdAt DateTime    @default(now())
  weight    Int
  userId    String?
  pollId    String
  optionId  String
  option    Option      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll      Poll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id])

  @@index([optionId], map: "vote_optionId_fkey")
  @@index([pollId], map: "vote_pollId_fkey")
  @@index([userId], map: "vote_userId_fkey")
  @@map("vote")
}

model Invoice {
  id          String      @id @default(uuid())
  amount      Decimal     @db.Decimal(10, 2)
  currency    String      @default("PHP")
  status      String      @default("PENDING")
  referenceId String?     @unique
  tier        PricingTier
  createdAt   DateTime    @default(now())
  userId      String?
  pollId      String?
  poll        Poll?       @relation(fields: [pollId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])

  @@index([pollId], map: "invoice_pollId_fkey")
  @@index([userId], map: "invoice_userId_fkey")
  @@map("invoice")
}

model Notification{
  id String @id @default(uuid())
  createdAt   DateTime    @default(now())
  type String
  path String
  userId String
  message String
  isRead    Boolean  @default(false)
  user User @relation(fields: [userId], references: [id])
  @@index([userId])
  @@map("notification")
}


enum PricingTier {
  FREE
  BASIC
  PREMIUM
}
